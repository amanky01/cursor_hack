# Next.js — Convex HTTP (rewrites /api → Convex site)
CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.convex.site

# Next.js — Convex React client (required for useQuery / useMutation / useAction)
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Clerk (staff: counsellor / admin sign-in)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Convex auth (Clerk JWT template "convex" — same issuer URL in Convex env)
# Clerk Dashboard → API Keys → Frontend API URL (e.g. https://xxx.clerk.accounts.dev)
CLERK_JWT_ISSUER_DOMAIN=https://YOUR_INSTANCE.clerk.accounts.dev

# Convex dashboard → Settings → Environment variables (not all needed in Next)
# LLM_PROVIDER=gemini | openai   (default: gemini)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o
# EXA_API_KEY=
# APIFY_TOKEN=
# APIFY_GOOGLE_SEARCH_ACTOR_ID=apify/google-search-scraper
#
# LangGraph ReAct agent: max iteration budget (maps to recursionLimit on Convex). Default 5.
# CHAT_AGENT_MAX_ITERATIONS=5
#
# Chat pipeline debug logs (Convex dashboard → Logs). Lines prefixed "[sehat_chat]" JSON.
# SEHAT_CHAT_TRACE=1
# SEHAT_CHAT_TRACE_VERBOSE=1
#
# Appointments page → hospitals: Convex HTTP /api/apify/hospitals (Next rewrites to CONVEX_SITE_URL).
# Set these in the Convex dashboard (same place as EXA_API_KEY / APIFY_TOKEN for search):
# APIFY_TOKEN=                    (already used by resource search)
# APIFY_HOSPITAL_DATASET_ID=      (optional: use this dataset instead of running an actor)
# APIFY_HOSPITAL_ACTOR_ID=        (optional: run this actor instead of default Google Maps scraper)
# APIFY_HOSPITAL_ACTOR_INPUT=     (optional JSON for the actor above)
# APIFY_HOSPITAL_SEARCH_QUERY=hospitals in Mumbai   (default Google Maps search when no dataset)
# APIFY_HOSPITAL_AUTO_RUN_DEFAULTS=false   (opt out: skip default actor; then set DATASET_ID or ACTOR_ID)

# Legacy JWT auth (students) — /login, /register, student chat token
# MUST be set for Convex (not in this file unless you use a local script):
#   npx convex env set JWT_SECRET "$(openssl rand -base64 32 | tr -d '\n')"
# Or: Convex dashboard → Settings → Environment variables → JWT_SECRET

# Optional: OpenAI for /api/symptom-check (falls back to rule-based if unset)
# OPENAI_API_KEY=

# Appointments stored in Convex when external directory API is not configured (guestAppointments).
# NEXT_PUBLIC_CONVEX_URL required for /api/appointments in that mode.
#
# External appointment / hospital directory API (server-side; key is never sent to the browser)
# When HEALTH_APPOINTMENTS_API_URL + KEY are set, /api/appointments uses this provider instead of Convex.
# HEALTH_APPOINTMENTS_API_URL=https://api.your-provider.com/v1
# HEALTH_APPOINTMENTS_API_KEY=your_secret_key
# Optional: send the key in a custom header instead of Authorization: Bearer …
# HEALTH_APPOINTMENTS_API_KEY_HEADER=x-api-key
