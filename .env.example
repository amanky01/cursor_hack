# Next.js: Convex HTTP base URL (Dashboard → Deployment → Show development credentials)
# Example: https://happy-animal-123.convex.cloud is the deployment URL; HTTP endpoints use .convex.site
CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.convex.site

# Optional: Convex dashboard URL for client-side Convex later (not required for axios + HTTP)
# NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# Optional: OpenAI for /api/symptom-check (falls back to rule-based if unset)
# OPENAI_API_KEY=

# Optional: override path for JSON appointment store (default: ./data/appointments.json)
# APPOINTMENTS_FILE=
